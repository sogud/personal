---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Sidebar from '../../components/Sidebar.astro';
import PhotographyGallery from '../../components/PhotographyGallery.astro';

export async function getStaticPaths() {
  const photography = await getCollection('photography');

  return photography.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = CollectionEntry<'photography'>;

const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title,
  description,
  images,
  location,
  camera,
  lens,
  settings,
  category,
  tags,
  pubDate,
} = entry.data;

const safeImages = Array.isArray(images) ? images.filter(Boolean) : [];
const coverImage = safeImages[0];
const formattedDate = pubDate instanceof Date
  ? pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const infoItems = [
  { label: 'Location', value: location },
  { label: 'Camera', value: camera },
  { label: 'Lens', value: lens },
  { label: 'Aperture', value: settings?.aperture && `f/${settings.aperture}` },
  { label: 'Shutter', value: settings?.shutterSpeed },
  { label: 'ISO', value: settings?.iso },
  { label: 'Focal', value: settings?.focalLength },
].filter((item) => item.value);

const safeTags = Array.isArray(tags) ? tags.filter(Boolean) : [];
const hasExtraImages = safeImages.length > 1;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`${title} - 摄影作品`} description={description} image={coverImage?.src} />
  </head>
  <body>
    <div class="layout">
      <Sidebar />
      <main class="wrapper">
        <article class="page">
          <header class="hero">
            <div class="hero-content">
              <div class="hero-meta-top">
                <a class="back-link" href="/photography/">← Photography</a>
                {category && <span class="category">{category}</span>}
              </div>
              
              <h1 class="title">{title}</h1>
              
              {description && <p class="description">{description}</p>}
              
              <div class="meta-info">
                {formattedDate && <span class="date">{formattedDate}</span>}
                {infoItems.length > 0 && (
                  <div class="tech-specs">
                    {infoItems.map((item, index) => (
                      <>
                        <span class="spec-item" title={item.label}>{item.value}</span>
                        {index < infoItems.length - 1 && <span class="separator">/</span>}
                      </>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </header>

          <section class="main-image-section">
            <figure class={`main-image ${coverImage ? '' : 'placeholder'}`}>
              {coverImage ? (
                <img src={coverImage.src} alt={coverImage.alt} loading="eager" />
              ) : (
                <div class="placeholder-text">暂无封面图片</div>
              )}
              {coverImage?.caption && <figcaption>{coverImage.caption}</figcaption>}
            </figure>
          </section>

          <section class="content-body">
            <div class="markdown">
              <Content />
            </div>
          </section>

          {hasExtraImages && (
            <section class="gallery-section">
              <PhotographyGallery images={safeImages.slice(1)} />
            </section>
          )}
          
          {safeTags.length > 0 && (
            <section class="tags-section">
              <div class="tags-list">
                {safeTags.map((tag) => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
            </section>
          )}
        </article>
      </main>
    </div>

    <style>
      :global(body) {
        margin: 0;
        background: #ffffff;
        color: #111827;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      .layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        min-height: 100vh;
      }

      @media (max-width: 1024px) {
        .layout {
          grid-template-columns: 1fr;
        }
      }

      .wrapper {
        padding: 0;
      }

      .page {
        max-width: 1200px;
        margin: 0 auto;
        padding-bottom: 5rem;
      }

      /* Hero Section */
      .hero {
        padding: 4rem 2rem 2rem;
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
      }

      .hero-meta-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        font-size: 0.9rem;
      }

      .back-link {
        text-decoration: none;
        color: #6b7280;
        transition: color 0.2s;
      }

      .back-link:hover {
        color: #111827;
      }

      .category {
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        font-size: 0.8rem;
      }

      .title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 400;
        line-height: 1.1;
        margin: 0 0 1rem;
        letter-spacing: -0.02em;
      }

      .description {
        font-size: 1.1rem;
        color: #4b5563;
        line-height: 1.6;
        margin: 0 0 2rem;
        font-weight: 300;
      }

      .meta-info {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
        font-size: 0.9rem;
        color: #9ca3af;
      }

      .tech-specs {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem;
      }

      .separator {
        color: #e5e7eb;
      }

      /* Main Image */
      .main-image-section {
        width: 100%;
        margin-bottom: 4rem;
      }

      .main-image {
        margin: 0;
        width: 100%;
      }

      .main-image img {
        width: 100%;
        height: auto;
        display: block;
        max-height: 85vh;
        object-fit: contain;
      }

      .placeholder {
        background: #f3f4f6;
        padding: 4rem;
        text-align: center;
        color: #9ca3af;
      }

      figcaption {
        text-align: center;
        color: #6b7280;
        font-size: 0.9rem;
        margin-top: 1rem;
        font-style: italic;
      }

      /* Content Body */
      .content-body {
        max-width: 720px;
        margin: 0 auto 4rem;
        padding: 0 2rem;
      }

      .markdown {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #374151;
      }

      .markdown :global(p) {
        margin-bottom: 1.5rem;
      }

      /* Tags */
      .tags-section {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 2rem;
        text-align: center;
      }

      .tags-list {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .tag {
        color: #9ca3af;
        font-size: 0.9rem;
      }

      /* Gallery Section */
      .gallery-section {
        padding: 0 2rem;
        margin-bottom: 4rem;
      }

      @media (max-width: 768px) {
        .hero {
          padding: 2rem 1.5rem 1rem;
        }
        
        .title {
          font-size: 2rem;
        }
        
        .content-body {
          padding: 0 1.5rem;
        }
      }

      @media (prefers-color-scheme: dark) {
        :global(body) {
          background: #111827;
          color: #f9fafb;
        }

        .back-link, .category, .description {
          color: #9ca3af;
        }

        .back-link:hover {
          color: #f9fafb;
        }

        .markdown {
          color: #d1d5db;
        }
        
        .placeholder {
          background: #1f2937;
        }
      }
    </style>
  </body>
</html>