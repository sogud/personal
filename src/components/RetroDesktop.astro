---
import type { MediaFolder } from '../data/mediaFolders';

type Props = {
  folders: MediaFolder[];
  activeSlug?: string;
  title?: string;
};

const { folders, activeSlug, title = 'Bamboo OS' } = Astro.props;
const currentTime = new Date().toLocaleTimeString('en-US', {
  hour: '2-digit',
  minute: '2-digit',
});
---

<div class="retro-shell" data-retro-desktop>
  <div class="retro-screen">
    <header class="retro-menu-bar">
      <a class="retro-avatar" href="/" aria-label="Home">
        <img src="https://github.com/sogud.png" alt="" />
      </a>
      <a class="retro-menu-item retro-menu-strong" href="/">Files</a>
      <a class="retro-menu-item" href="/folders/writing/">Writing</a>
      <a class="retro-menu-item" href="/apps/terminal/">Terminal</a>
      <a class="retro-menu-item" href="/about/">System</a>
      <time class="retro-clock">{currentTime}</time>
    </header>

    <main class="retro-desktop" aria-label={title}>
      <slot />
    </main>

    <nav class="retro-folder-dock" aria-label="Media folders">
      {folders.map((folder) => (
        <a
          class:list={[
            'retro-folder-link',
            activeSlug === folder.slug && 'is-active',
          ]}
          href={`/folders/${folder.slug}/`}
        >
          <span class="retro-folder-icon" aria-hidden="true"></span>
          <span class="retro-folder-name">{folder.title}</span>
        </a>
      ))}
      <a
        class:list={[
          'retro-folder-link',
          'retro-app-link',
          title === 'Terminal' && 'is-active',
        ]}
        href="/apps/terminal/"
      >
        <span class="retro-terminal-icon" aria-hidden="true">$_</span>
        <span class="retro-folder-name">Terminal</span>
      </a>
    </nav>

    <div class="retro-crt-overlay" aria-hidden="true">
      <div class="retro-crt-grid"></div>
      <div class="retro-crt-soft"></div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const closeButton = target.closest('[data-retro-close]');
    if (!(closeButton instanceof HTMLElement)) return;

    const windowElement = closeButton.closest('.retro-window, .retro-home-window');
    if (!(windowElement instanceof HTMLElement)) return;

    event.preventDefault();
    windowElement.setAttribute('hidden', '');
  });

  const dragState = {
    window: null,
    desktop: null,
    offsetX: 0,
    offsetY: 0,
  };

  function clamp(value, min, max) {
    return Math.max(min, Math.min(value, max));
  }

  document.addEventListener('pointerdown', (event) => {
    if (event.button !== 0) return;
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    if (target.closest('button, a, input, select, textarea, summary')) return;

    const bar = target.closest('.retro-window-bar');
    if (!(bar instanceof HTMLElement)) return;

    const windowElement = bar.closest('.retro-window, .retro-home-window');
    const desktop = windowElement?.closest('.retro-desktop');
    if (!(windowElement instanceof HTMLElement) || !(desktop instanceof HTMLElement)) return;
    if (window.matchMedia('(max-width: 900px)').matches) return;

    const windowRect = windowElement.getBoundingClientRect();
    const desktopRect = desktop.getBoundingClientRect();

    windowElement.style.position = 'absolute';
    windowElement.style.left = `${windowRect.left - desktopRect.left}px`;
    windowElement.style.top = `${windowRect.top - desktopRect.top}px`;
    windowElement.style.margin = '0';
    windowElement.classList.add('is-dragging');

    dragState.window = windowElement;
    dragState.desktop = desktop;
    dragState.offsetX = event.clientX - windowRect.left;
    dragState.offsetY = event.clientY - windowRect.top;

    bar.setPointerCapture(event.pointerId);
    event.preventDefault();
  });

  document.addEventListener('pointermove', (event) => {
    if (!(dragState.window instanceof HTMLElement) || !(dragState.desktop instanceof HTMLElement)) return;

    const desktopRect = dragState.desktop.getBoundingClientRect();
    const maxLeft = Math.max(0, desktopRect.width - dragState.window.offsetWidth);
    const maxTop = Math.max(0, desktopRect.height - dragState.window.offsetHeight);
    const left = clamp(event.clientX - desktopRect.left - dragState.offsetX, 0, maxLeft);
    const top = clamp(event.clientY - desktopRect.top - dragState.offsetY, 0, maxTop);

    dragState.window.style.left = `${left}px`;
    dragState.window.style.top = `${top}px`;
  });

  document.addEventListener('pointerup', () => {
    if (dragState.window instanceof HTMLElement) {
      dragState.window.classList.remove('is-dragging');
    }
    dragState.window = null;
    dragState.desktop = null;
  });
</script>
