---
import BaseHead from '../components/BaseHead.astro';

import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <main class="container mx-auto px-4 pt-10 space-y-5">
      <h1 class="text-xl font-black">{SITE_TITLE}</h1>
      <p>{SITE_DESCRIPTION}</p>
      <p>
        Welcome follow my <a
          class="font-extralight text-blue-500"
          href="https://github.com/sogud"
          >github!</a
        >
      </p>
    </main>
  </body>
</html>
