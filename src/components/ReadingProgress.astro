<div id="reading-progress" class="reading-progress">
  <div class="reading-progress-bar"></div>
</div>

<script>
  // 使用 requestAnimationFrame 实现高性能滚动监听
  (function() {
    const progressBar = document.querySelector('.reading-progress-bar');
    if (!progressBar) return;

    let ticking = false;
    let article = null;

    function updateProgress() {
      if (!article) {
        article = document.querySelector('article');
        if (!article) {
          ticking = false;
          return;
        }
      }

      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const windowHeight = window.innerHeight;
      const scrollTop = window.scrollY;

      const articleBottom = articleTop + articleHeight - windowHeight;
      const progress = Math.max(0, Math.min(100, ((scrollTop - articleTop) / (articleBottom - articleTop)) * 100));

      progressBar.style.width = `${progress}%`;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateProgress);
        ticking = true;
      }
    }, { passive: true });

    // 初始更新
    updateProgress();
  })();
</script>
