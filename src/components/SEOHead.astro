---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  noindex?: boolean;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = 'Sogud',
  tags = [],
  noindex = false
} = Astro.props || {};

const finalTitle = title || SITE_TITLE || 'Sogud.me';
const finalDescription = description || SITE_DESCRIPTION || '';
const finalImage = image || '/placeholder-social.jpg';
const finalTags = Array.isArray(tags) ? tags : [];

const fullTitle = finalTitle === SITE_TITLE ? finalTitle : `${finalTitle} - ${SITE_TITLE}`;

// 安全创建 canonicalURL
let canonicalURL: URL;
try {
  const pathname = Astro.url?.pathname || '/';
  canonicalURL = new URL(pathname, SITE_URL);
} catch (error) {
  console.error('Error creating canonical URL:', error);
  canonicalURL = new URL('/', SITE_URL);
}

// 安全创建图片 URL
function getImageUrl(imgPath: string): string {
  try {
    return new URL(imgPath, SITE_URL).toString();
  } catch (error) {
    return `${SITE_URL}${imgPath}`;
  }
}
---

<!-- SEO 优化元数据 -->
<title>{fullTitle}</title>
<meta name="description" content={finalDescription} />
<meta name="author" content={author} />

{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- 关键词 -->
{finalTags.length > 0 && <meta name="keywords" content={finalTags.join(', ')} />}

<!-- 语言 -->
<meta name="language" content="zh-CN" />

<!-- 地理标签 -->
<meta name="geo.region" content="CN" />
<meta name="geo.placename" content="China" />

<!-- 分类 -->
<meta name="category" content="Technology" />

<!-- 版权 -->
<meta name="copyright" content={`© ${new Date().getFullYear()} ${SITE_TITLE}`} />

<!-- 重新访问 -->
<meta name="revisit-after" content="7 days" />

<!-- 分发 -->
<meta name="distribution" content="global" />

<!-- 评级 -->
<meta name="rating" content="general" />

<!-- 应用名称 -->
<meta name="application-name" content={SITE_TITLE} />

<!-- 移动优化 -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content={SITE_TITLE} />

<!-- 微软应用 -->
<meta name="msapplication-TileColor" content="#1f2937" />
<meta name="msapplication-config" content="/browserconfig.xml" />

<!-- 预连接优化 -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- DNS 预取 -->
<link rel="dns-prefetch" href="//fonts.googleapis.com" />
<link rel="dns-prefetch" href="//fonts.gstatic.com" />

<!-- 规范链接 -->
<link rel="canonical" href={canonicalURL.toString()} />

<!-- 备用语言 -->
<link rel="alternate" hreflang="zh-CN" href={canonicalURL.toString()} />
<link rel="alternate" hreflang="x-default" href={canonicalURL.toString()} />

<!-- Open Graph 增强 -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.toString()} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={getImageUrl(finalImage)} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="zh_CN" />
<meta property="og:locale:alternate" content="en_US" />

{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && author && (
  <meta property="article:author" content={author} />
)}
{type === 'article' && finalTags.map(tag => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter 增强 -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL.toString()} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={getImageUrl(finalImage)} />
<meta name="twitter:image:alt" content={fullTitle} />
<meta name="twitter:creator" content="@sogud" />
<meta name="twitter:site" content="@sogud" />

<!-- 结构化数据 -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": type === 'article' ? "BlogPosting" : "WebSite",
  "headline": fullTitle,
  "description": finalDescription,
  "image": getImageUrl(finalImage),
  "url": canonicalURL.toString(),
  "datePublished": publishedTime,
  "dateModified": modifiedTime || publishedTime,
  "author": {
    "@type": "Person",
    "name": author,
    "url": SITE_URL,
    "sameAs": [
      "https://github.com/sogud",
      "https://twitter.com/sogud"
    ]
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE_TITLE,
    "url": SITE_URL,
    "logo": {
      "@type": "ImageObject",
      "url": getImageUrl("/favicon.svg"),
      "width": 32,
      "height": 32
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL.toString()
  },
  ...(type === 'article' && {
    "keywords": finalTags.join(', '),
    "articleSection": "Technology",
    "inLanguage": "zh-CN",
    "wordCount": finalDescription.length,
    "isPartOf": {
      "@type": "Blog",
      "name": SITE_TITLE,
      "url": SITE_URL
    }
  }),
  ...(type === 'website' && {
    "name": SITE_TITLE,
    "alternateName": "Sogud's Tech Blog",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${SITE_URL}/blog/?q={search_term_string}`
      },
      "query-input": "required name=search_term_string"
    }
  })
})} />
