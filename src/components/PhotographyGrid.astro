---
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'photography'>[];
  featured?: boolean;
}

const { items, featured = false } = Astro.props;
---

<div class={`photography-grid ${featured ? 'featured-grid' : 'all-grid'}`}>
  {items.map((item) => {
    const { title, description, images, category, pubDate, location, camera, settings } = item.data;
    const mainImage = images[0];
    
    return (
      <article class="photography-item" data-category={category}>
        <a href={`/photography/${item.slug}/`} class="photography-link">
          <div class="image-wrapper">
            <div class="image-container">
              <img
                src={mainImage.src}
                alt={mainImage.alt}
                width={mainImage.width}
                height={mainImage.height}
                loading="lazy"
                class="photography-image"
              />
            </div>
            <div class="image-overlay">
              <div class="overlay-content">
                <h3 class="item-title-overlay">{title}</h3>
                <time datetime={pubDate.toISOString()} class="publish-date-overlay">
                  {pubDate.toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  })}
                </time>
              </div>
            </div>
          </div>
        </a>
      </article>
    );
  })}
</div>

<style>
  .photography-grid {
    display: grid;
    gap: 2px; /* 极简网格间距 */
    margin-top: 1rem;
  }

  .featured-grid {
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
  }

  .all-grid {
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .photography-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: #f3f4f6; /* 图片加载前的占位色 */
  }

  .photography-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .image-container {
    width: 100%;
    height: 100%;
  }

  .photography-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
    display: block;
  }

  .photography-item:hover .photography-image {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.3); /* 默认轻微遮罩，让文字可见 */
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
  }

  .photography-item:hover .image-overlay {
    opacity: 1;
  }

  .overlay-content {
    width: 100%;
    transform: translateY(10px);
    transition: transform 0.3s ease;
  }

  .photography-item:hover .overlay-content {
    transform: translateY(0);
  }

  .item-title-overlay {
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0 0 0.25rem 0;
    color: white;
    letter-spacing: 0.01em;
  }

  .publish-date-overlay {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 300;
  }

  /* 深色模式适配 */
  @media (prefers-color-scheme: dark) {
    .photography-item {
      background: #1f2937;
    }
  }

  /* 响应式设计 */
  @media (max-width: 768px) {
    .photography-grid {
      gap: 1px;
    }
    
    .featured-grid,
    .all-grid {
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }

    /* 移动端保持可见 */
    .image-overlay {
      opacity: 1;
      background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
      padding: 1rem;
    }

    .overlay-content {
      transform: translateY(0);
    }

    .item-title-overlay {
      font-size: 1rem;
    }
  }
</style>