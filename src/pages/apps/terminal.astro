---
import { ViewTransitions } from 'astro:transitions';
import BaseHead from '../../components/BaseHead.astro';
import RetroDesktop from '../../components/RetroDesktop.astro';
import { SITE_TITLE } from '../../consts';
import { mediaFolders } from '../../data/mediaFolders';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <BaseHead
      title={`Terminal - ${SITE_TITLE}`}
      description="AI terminal"
      type="website"
    />
    <ViewTransitions />
  </head>
  <body class="retro-body">
    <RetroDesktop folders={mediaFolders} title="Terminal">
      <section class="retro-window retro-terminal-window">
        <header class="retro-window-bar">
          <button class="retro-close" type="button" data-retro-close aria-label="Close terminal">x</button>
          <span class="retro-window-title">Terminal</span>
        </header>

        <div class="retro-window-content retro-terminal-content">
          <div class="retro-terminal-chrome" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <form class="retro-terminal-settings" data-terminal-settings>
            <div class="retro-terminal-auth">
              <button type="button" data-openrouter-login>OpenRouter Login</button>
              <span data-openrouter-status>not connected</span>
              <button type="button" data-openrouter-disconnect aria-label="Clear OpenRouter session">clear</button>
            </div>

            <details class="retro-terminal-more">
              <summary>more</summary>
              <div class="retro-terminal-more-panel">
                <label>
                  Provider
                  <select data-terminal-provider>
                    <option value="openrouter">OpenRouter</option>
                    <option value="openai">OpenAI</option>
                    <option value="deepseek">DeepSeek</option>
                    <option value="groq">Groq</option>
                    <option value="mistral">Mistral</option>
                  </select>
                </label>
                <label>
                  Model
                  <input
                    data-terminal-model
                    autocomplete="off"
                    list="openrouter-free-models"
                    placeholder="deepseek/deepseek-v4-flash:free"
                  />
                  <datalist id="openrouter-free-models" data-openrouter-free-models></datalist>
                </label>
                <label>
                  API Key
                  <input data-terminal-key type="password" autocomplete="off" placeholder="paste user-owned key" />
                </label>
                <div class="retro-terminal-session-tools">
                  <label>
                    Session
                    <select data-terminal-session></select>
                  </label>
                  <button type="button" data-terminal-new-session>new</button>
                </div>
              </div>
            </details>
          </form>

          <div class="retro-terminal-screen" data-terminal-screen>
            <div class="retro-terminal-lines" data-terminal-lines>
              <p class="retro-terminal-line retro-terminal-system">
                <span>system</span> BYOK proxy terminal ready.
              </p>
              <p class="retro-terminal-line retro-terminal-system">
                <span>system</span> Bring your own provider key. This site only forwards requests.
              </p>
            </div>

            <form class="retro-terminal-form" data-terminal-form>
              <input
                id="terminal-input"
                class="retro-terminal-input"
                data-terminal-input
                aria-label="Ask AI"
                autocomplete="off"
                spellcheck="false"
                placeholder="Ask AI..."
              />
              <button class="retro-terminal-send" type="submit">send</button>
            </form>
          </div>
        </div>
      </section>
    </RetroDesktop>

    <script>
      const form = document.querySelector('[data-terminal-form]');
      const input = document.querySelector('[data-terminal-input]');
      const lines = document.querySelector('[data-terminal-lines]');
      const screen = document.querySelector('[data-terminal-screen]');
      const providerInput = document.querySelector('[data-terminal-provider]');
      const modelInput = document.querySelector('[data-terminal-model]');
      const keyInput = document.querySelector('[data-terminal-key]');
      const openRouterLogin = document.querySelector('[data-openrouter-login]');
      const openRouterDisconnect = document.querySelector('[data-openrouter-disconnect]');
      const openRouterStatus = document.querySelector('[data-openrouter-status]');
      const openRouterFreeModels = document.querySelector('[data-openrouter-free-models]');
      const sessionInput = document.querySelector('[data-terminal-session]');
      const newSessionButton = document.querySelector('[data-terminal-new-session]');

      const settingsKey = 'retro-terminal-settings';
      const apiKeyKey = 'retro-terminal-api-key';
      const sessionsKey = 'retro-terminal-sessions';
      const activeSessionKey = 'retro-terminal-active-session';

      const introLines = [
        ['system', 'system', 'BYOK proxy terminal ready.'],
        ['system', 'system', 'Bring your own provider key. This site only forwards requests.'],
      ];

      const providerDefaults = {
        openrouter: 'deepseek/deepseek-v4-flash:free',
        openai: 'gpt-4o-mini',
        deepseek: 'deepseek-chat',
        groq: 'llama-3.1-8b-instant',
        mistral: 'mistral-small-latest',
      };

      function readSettings() {
        return {
          provider: providerInput instanceof HTMLSelectElement ? providerInput.value : 'openrouter',
          model: modelInput instanceof HTMLInputElement ? modelInput.value.trim() : '',
          apiKey: keyInput instanceof HTMLInputElement ? keyInput.value.trim() : '',
        };
      }

      function saveSettings() {
        const settings = readSettings();
        localStorage.setItem(settingsKey, JSON.stringify({
          provider: settings.provider,
          model: settings.model,
        }));
        if (keyInput instanceof HTMLInputElement) {
          sessionStorage.setItem(apiKeyKey, settings.apiKey);
        }
      }

      function setOpenRouterStatus(text) {
        if (openRouterStatus instanceof HTMLElement) {
          openRouterStatus.textContent = text;
        }
        if (openRouterLogin instanceof HTMLButtonElement) {
          openRouterLogin.hidden = text === 'connected';
        }
        if (openRouterStatus instanceof HTMLElement) {
          openRouterStatus.closest('.retro-terminal-auth')?.classList.toggle('is-connected', text === 'connected');
        }
      }

      function loadSettings() {
        const saved = localStorage.getItem(settingsKey);

        if (saved) {
          try {
            const settings = JSON.parse(saved);
            if (providerInput instanceof HTMLSelectElement && typeof settings.provider === 'string') {
              providerInput.value = settings.provider;
            }
            if (modelInput instanceof HTMLInputElement && typeof settings.model === 'string') {
              modelInput.value = settings.model;
            }
          } catch (error) {
            localStorage.removeItem(settingsKey);
          }
        }

        if (keyInput instanceof HTMLInputElement) {
          keyInput.value = sessionStorage.getItem(apiKeyKey) || '';
          if (keyInput.value) {
            setOpenRouterStatus('connected');
          }
        }
      }

      function syncProviderDefaults() {
        if (!(providerInput instanceof HTMLSelectElement) || !(modelInput instanceof HTMLInputElement)) return;
        if (!modelInput.value.trim()) {
          modelInput.placeholder = providerDefaults[providerInput.value] || 'model-name';
          if (providerInput.value === 'openrouter') {
            modelInput.value = providerDefaults.openrouter;
          }
        }
      }

      async function loadOpenRouterFreeModels() {
        if (!(modelInput instanceof HTMLInputElement) || !(openRouterFreeModels instanceof HTMLDataListElement)) return;

        try {
          const response = await fetch('/api/openrouter/free-models');
          const payload = await response.json().catch(() => ({}));
          if (!response.ok || !Array.isArray(payload.models)) return;

          openRouterFreeModels.innerHTML = '';
          for (const model of payload.models.slice(0, 80)) {
            if (!model?.id) continue;
            const option = document.createElement('option');
            option.value = model.id;
            option.label = model.name || model.id;
            openRouterFreeModels.append(option);
          }

          const ids = payload.models.map((model) => model.id);
          if (typeof ids[0] === 'string') {
            providerDefaults.openrouter = ids[0];
          }

          if (providerInput instanceof HTMLSelectElement && providerInput.value === 'openrouter') {
            const currentModel = modelInput.value.trim();
            if (
              !currentModel
              || currentModel === 'openai/gpt-4o-mini'
              || currentModel === 'deepseek/deepseek-v4-flash:free'
            ) {
              modelInput.value = providerDefaults.openrouter;
              saveSettings();
            }
          }
        } catch (error) {
          // The static fallback model remains usable if the models endpoint is unreachable.
        }
      }

      function createSession() {
        return {
          id: `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`,
          title: 'new session',
          createdAt: Date.now(),
          messages: [],
        };
      }

      function loadSessions() {
        try {
          const parsed = JSON.parse(localStorage.getItem(sessionsKey) || '[]');
          if (Array.isArray(parsed) && parsed.length) {
            return parsed;
          }
        } catch (error) {
          localStorage.removeItem(sessionsKey);
        }
        const session = createSession();
        localStorage.setItem(sessionsKey, JSON.stringify([session]));
        localStorage.setItem(activeSessionKey, session.id);
        return [session];
      }

      function saveSessions(sessions) {
        localStorage.setItem(sessionsKey, JSON.stringify(sessions.slice(0, 20)));
      }

      function getActiveSession(sessions = loadSessions()) {
        const activeId = localStorage.getItem(activeSessionKey);
        return sessions.find((session) => session.id === activeId) || sessions[0];
      }

      function renderSessionSelect(sessions = loadSessions()) {
        if (!(sessionInput instanceof HTMLSelectElement)) return;
        const activeSession = getActiveSession(sessions);
        sessionInput.innerHTML = '';
        for (const session of sessions) {
          const option = document.createElement('option');
          option.value = session.id;
          option.textContent = session.title || 'new session';
          sessionInput.append(option);
        }
        sessionInput.value = activeSession.id;
      }

      function renderMessages() {
        if (!(lines instanceof HTMLElement)) return;
        const sessions = loadSessions();
        const activeSession = getActiveSession(sessions);
        lines.innerHTML = '';
        for (const [kind, label, text] of introLines) {
          appendLine(kind, label, text, false);
        }
        for (const message of activeSession.messages || []) {
          appendLine(message.kind, message.label, message.text, false);
        }
      }

      function persistMessage(kind, label, text) {
        const sessions = loadSessions();
        const activeSession = getActiveSession(sessions);
        activeSession.messages = Array.isArray(activeSession.messages) ? activeSession.messages : [];
        activeSession.messages.push({ kind, label, text });
        if (activeSession.title === 'new session' && kind === 'user') {
          activeSession.title = text.slice(0, 32) || 'new session';
        }
        saveSessions(sessions);
        renderSessionSelect(sessions);
      }

      function randomBase64URL(bytes) {
        const array = new Uint8Array(bytes);
        crypto.getRandomValues(array);
        let binary = '';
        for (const byte of array) {
          binary += String.fromCharCode(byte);
        }
        return btoa(binary)
          .replace(/\+/g, '-')
          .replace(/\//g, '_')
          .replace(/=+$/g, '');
      }

      async function createCodeChallenge(verifier) {
        const data = new TextEncoder().encode(verifier);
        const hash = await crypto.subtle.digest('SHA-256', data);
        let binary = '';
        for (const byte of new Uint8Array(hash)) {
          binary += String.fromCharCode(byte);
        }
        return btoa(binary)
          .replace(/\+/g, '-')
          .replace(/\//g, '_')
          .replace(/=+$/g, '');
      }

      async function startOpenRouterLogin() {
        const verifier = randomBase64URL(64);
        const challenge = await createCodeChallenge(verifier);
        sessionStorage.setItem('openrouter-code-verifier', verifier);
        sessionStorage.setItem('openrouter-callback-path', window.location.pathname);

        const callbackURL = `${window.location.origin}${window.location.pathname}`;
        const authURL = new URL('https://openrouter.ai/auth');
        authURL.searchParams.set('callback_url', callbackURL);
        authURL.searchParams.set('code_challenge', challenge);
        authURL.searchParams.set('code_challenge_method', 'S256');
        window.location.href = authURL.toString();
      }

      async function finishOpenRouterLogin() {
        const params = new URLSearchParams(window.location.search);
        const code = params.get('code');
        if (!code) return;

        const verifier = sessionStorage.getItem('openrouter-code-verifier');
        if (!verifier) {
          appendLine('system', 'error', 'OpenRouter login verifier is missing. Try logging in again.');
          return;
        }

        setOpenRouterStatus('connecting...');
        try {
          const response = await fetch('/api/openrouter/oauth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ code, codeVerifier: verifier }),
          });
          const payload = await response.json().catch(() => ({}));
          if (!response.ok || !payload.key) {
            appendLine('system', 'error', payload.error || 'OpenRouter login failed.');
            setOpenRouterStatus('not connected');
            return;
          }

          if (providerInput instanceof HTMLSelectElement) {
            providerInput.value = 'openrouter';
          }
          if (modelInput instanceof HTMLInputElement && !modelInput.value.trim()) {
            modelInput.value = providerDefaults.openrouter;
          }
          if (keyInput instanceof HTMLInputElement) {
            keyInput.value = payload.key;
            sessionStorage.setItem(apiKeyKey, payload.key);
          }
          sessionStorage.removeItem('openrouter-code-verifier');
          saveSettings();
          setOpenRouterStatus('connected');
        } catch (error) {
          appendLine('system', 'error', 'OpenRouter login exchange is unavailable.');
          setOpenRouterStatus('not connected');
        } finally {
          const cleanURL = `${window.location.origin}${window.location.pathname}`;
          window.history.replaceState({}, document.title, cleanURL);
        }
      }

      function appendLine(kind, label, text, persist = true) {
        if (!(lines instanceof HTMLElement)) return;
        const row = document.createElement('p');
        row.className = `retro-terminal-line retro-terminal-${kind}`;
        const tag = document.createElement('span');
        tag.textContent = label;
        row.append(tag, ` ${text}`);
        lines.append(row);
        if (screen instanceof HTMLElement) {
          screen.scrollTop = screen.scrollHeight;
        }
        if (persist) {
          persistMessage(kind, label, text);
        }
        return row;
      }

      async function submitMessage(message) {
        const settings = readSettings();
        if (!settings.apiKey) {
          appendLine('system', 'error', 'Enter your own provider API key first.');
          return;
        }

        saveSettings();
        appendLine('user', 'you', message);
        const thinkingLine = appendLine('system', 'thinking', '...', false);

        try {
          const response = await fetch('/api/ai/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              message,
              provider: settings.provider,
              model: settings.model,
              apiKey: settings.apiKey,
            }),
          });
          const payload = await response.json().catch(() => ({}));
          thinkingLine?.remove();

          if (!response.ok) {
            appendLine('system', 'error', payload.error || 'AI backend is not configured.');
            return;
          }

          appendLine('assistant', 'ai', payload.reply || 'Empty response.');
        } catch (error) {
          thinkingLine?.remove();
          appendLine('system', 'error', 'AI backend is unavailable in this environment.');
        }
      }

      loadSettings();
      loadOpenRouterFreeModels();
      syncProviderDefaults();
      renderSessionSelect();
      renderMessages();

      if (providerInput instanceof HTMLSelectElement) {
        providerInput.addEventListener('change', () => {
          if (modelInput instanceof HTMLInputElement) {
            modelInput.value = '';
          }
          syncProviderDefaults();
          saveSettings();
        });
      }

      if (modelInput instanceof HTMLInputElement) {
        modelInput.addEventListener('input', saveSettings);
      }

      if (keyInput instanceof HTMLInputElement) {
        keyInput.addEventListener('input', saveSettings);
      }

      if (sessionInput instanceof HTMLSelectElement) {
        sessionInput.addEventListener('change', () => {
          localStorage.setItem(activeSessionKey, sessionInput.value);
          renderMessages();
        });
      }

      if (newSessionButton instanceof HTMLButtonElement) {
        newSessionButton.addEventListener('click', () => {
          const sessions = loadSessions();
          const session = createSession();
          sessions.unshift(session);
          saveSessions(sessions);
          localStorage.setItem(activeSessionKey, session.id);
          renderSessionSelect(sessions);
          renderMessages();
        });
      }

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const loginButton = target.closest('[data-openrouter-login]');
        if (loginButton instanceof HTMLButtonElement) {
          event.preventDefault();
          startOpenRouterLogin();
        }
      });

      if (openRouterDisconnect instanceof HTMLButtonElement) {
        openRouterDisconnect.addEventListener('click', () => {
          if (keyInput instanceof HTMLInputElement) {
            keyInput.value = '';
          }
          sessionStorage.removeItem(apiKeyKey);
          sessionStorage.removeItem('openrouter-code-verifier');
          setOpenRouterStatus('not connected');
        });
      }

      finishOpenRouterLogin();

      if (form instanceof HTMLFormElement && input instanceof HTMLInputElement) {
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          const message = input.value.trim();
          if (!message) return;
          input.value = '';
          submitMessage(message);
        });
      }
    </script>
  </body>
</html>
